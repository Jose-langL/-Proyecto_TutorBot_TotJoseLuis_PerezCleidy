        "url": "https://api.telegram.org/bot8692513632:AAFTnD0ocf0h9y0d-dZpvvgS991b9ICT2q4/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"chat_id\": \"{{ $('Code in JavaScript').item.json.ruta.chatid }}\",\n  \"text\": \"¡Genial! Estás a un clic de tus tutorías. Completa tu registro.\",\n  \"reply_markup\": {\n    \"inline_keyboard\": [\n      [\n        {\n          \"text\": \"📝 Registrarse\",\n          \"url\": \"https://jose-langl.github.io/formulario_n8n/?chatId={{ $('Code in JavaScript').item.json.ruta.chatid }}\"\n        }\n      ]\n    ]\n  }\n}",
