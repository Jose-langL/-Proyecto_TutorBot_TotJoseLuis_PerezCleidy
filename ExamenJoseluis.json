    {
      "parameters": {
        "jsCode": "const webhookInput = $('Webhook').first();\nconst datosForm = webhookInput ? webhookInput.json.body : null;\n\n// 2. Obtener todos los items actuales de la hoja (que vienen del nodo 'Get row(s) in sheet')\nconst todosLosRegistros = items;\n\n// 3. Inicializar contadores para calcular los IDs más altos\nlet maxIdTutoria = 0;\nlet maxIdEstudiante = 0;\n\nfor (const registro of todosLosRegistros) {\n    // Buscar el ID de tutoría más alto (Formato: TUT00X)\n    const idTutoriaStr = registro.json.id_tutoria; \n    if (idTutoriaStr && typeof idTutoriaStr === 'string') {\n        const idTutoriaNum = parseInt(idTutoriaStr.replace('TUT', ''), 10);\n        if (!isNaN(idTutoriaNum) && idTutoriaNum > maxIdTutoria) {\n            maxIdTutoria = idTutoriaNum;\n        }\n    }\n\n    // Buscar el ID de estudiante más alto (Formato: E00X)\n    const idEstudianteStr = registro.json.id_estudiante; \n    if (idEstudianteStr && typeof idEstudianteStr === 'string') {\n        const idEstudianteNum = parseInt(idEstudianteStr.replace('E', ''), 10);\n        if (!isNaN(idEstudianteNum) && idEstudianteNum > maxIdEstudiante) {\n            maxIdEstudiante = idEstudianteNum;\n        }\n    }\n}\n\n// 4. Generar los nuevos IDs autoincrementales\nconst nuevoIdTutoria = 'TUT' + (maxIdTutoria + 1).toString().padStart(3, '0');\nconst nuevoIdEstudiante = 'E' + (maxIdEstudiante + 1).toString().padStart(3, '0');\n\n// 5. Retornar la información del webhook formateada con ambos IDs generados\nreturn [{\n    json: {\n        id_tutoria: nuevoIdTutoria,\n        id_estudiante: nuevoIdEstudiante,\n        nombre: datosForm.nombres,\n        email: datosForm.email,\n        materia: datosForm.materia,\n        chatId: datosForm.chatid\n    }\n}];"
      },
