    {
      "parameters": {
        "jsCode": "const filas = $input.all();\n\n\nconst botones = filas.map(item => {\n  return [{\n    text: item.json.especialidad_materias,\n    callback_data: `materia_${item.json.especialidad_materias}`\n  }];\n});\n\nbotones.push([{\n  text: \"⬅️ Regresar al menú principal\",\n  callback_data: \"menu_principal\"\n}]);\n\nreturn [{\n  json: {\n    chat_id: $('Code in JavaScript').first().json.ruta.chatid,\n    text: \"🤓 ¿Qué materia te gustaría repasar hoy?\",\n    reply_markup: {\n      inline_keyboard: botones\n    }\n  }\n}];"
      },
