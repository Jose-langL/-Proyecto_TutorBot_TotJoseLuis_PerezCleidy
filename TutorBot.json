        "specifyBody": "json",
        "jsonBody": "={\n  \"chat_id\": \"{{ $('Code in JavaScript1').first().json.ruta.chatid }}\",\n  \"text\": \"¿Cómo podemos ayudarte hoy?\",\n  \"reply_markup\": {\n    \"inline_keyboard\": [\n      [\n        {\n          \"text\": \"📚 Solicitar tutoría\",\n          \"callback_data\": \"menu_solicitar\"\n        }\n      ],\n      [\n        {\n          \"text\": \" Registrarse\",\n          \"callback_data\": \"menu_consultar\"\n        }\n      ]\n    ]\n  }\n}",
        "options": {}
