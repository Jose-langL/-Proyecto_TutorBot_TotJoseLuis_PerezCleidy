    {
      "parameters": {
        "jsCode": "const todasLasMaterias = $input.all();\nconst valorSeleccionado = $('Code in JavaScript').first().json.ruta.valor;\n\n// 1. Filtramos para encontrar la materia exacta\nconst materia = todasLasMaterias.find(item => \n  item.json.Materia.toLowerCase() === valorSeleccionado.toLowerCase()\n);\n\n// 2. Construimos el mensaje usando backticks (`)\nif (materia) {\n  const mensaje = `🎓 *Detalle de la Tutoría*\n\n*Materia:* ${materia.json.Materia}\n*Día:* ${materia.json.dia_semana}\n*Horario:* ${materia.json.hora_inicio} - ${materia.json.hora_fin}\n*Precio:* ${materia.json.precio}\n*Estado:* ${materia.json.estado}\n\n¡Espero que esta información te sea de gran ayuda!`;\n\n  return [{\n    json: {\n      chat_id: $('Code in JavaScript').first().json.ruta.chatid,\n      text: mensaje,\n      parse_mode: \"Markdown\"\n    }\n  }];\n} else {\n  return [{\n    json: {\n      chat_id: $('Code in JavaScript').first().json.ruta.chatid,\n      text: \"❌ Lo siento, no encontré información para la materia: \" + valorSeleccionado\n    }\n  }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2592,
        2768
      ],
      "id": "2768be73-8a73-45eb-a198-5b3ea7260dba",
      "name": "Code in JavaScript3"
    },
    {
      "parameters": {
        "jsCode": "let ruta = \"\";\nconst input = $input.first().json;\n\nif(input.callback_query){\n    const callbackData = input.callback_query.data;\n    // Hacemos el split. Ejemplo: \"materia_java\" -> [\"materia\", \"java\"]\n    const partes = callbackData.split('_');\n    \n    ruta = {\n        tipo: 'callback',\n        chatid: input.callback_query.message.chat.id,\n        raw_data: callbackData,\n        // Si el formato siempre es prefijo_valor, tomamos el primer elemento como sub-tipo\n        sub_tipo: partes[0] || 'unknown', \n        valor: partes[1] || ''\n    };\n\n} else if (input.message){\n    ruta = {\n        tipo: 'message',\n        chatid: input.message.chat.id,\n        data: input.message.text\n    };\n}\n\nreturn {\n    ruta\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
