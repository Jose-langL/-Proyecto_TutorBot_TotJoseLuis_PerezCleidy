      "parameters": {
        "jsCode": "const filas = $input.all();\n\n// Generamos los botones de materias\nconst botones = filas.map(item => {\n  return [{\n    text: item.json.Materia,\n    callback_data: `materia_${item.json.Materia}`\n  }];\n});\n\n// AGREGAMOS el botón de regreso al final de la lista\nbotones.push([{\n  text: \"⬅️ Regresar al menú principal\",\n  callback_data: \"menu_principal\"\n}]);\n\nreturn [{\n  json: {\n    chat_id: $('Code in JavaScript1').first().json.ruta.chatid,\n    text: \"Selecciona una materia para continuar:\",\n    reply_markup: {\n      inline_keyboard: botones\n    }\n  }\n}];"
      },
